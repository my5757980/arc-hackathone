# =============================================================
# AgentFlow — Agentic Economy on Arc
# HOW TO SETUP:
#   1. cp .env.example .env
#   2. Fill in CIRCLE_API_KEY, CIRCLE_ENTITY_SECRET, GEMINI_API_KEY, DATABASE_URL
#   3. Get Circle credentials at: https://console.circle.com
#   4. Get Gemini key at: https://aistudio.google.com
#   5. Get Neon DB at: https://neon.tech (free tier works)
# =============================================================

# --- Circle API (REQUIRED) ---
# Get from: https://console.circle.com → API Keys
CIRCLE_API_KEY=TEST_API_KEY:your_key_here

# --- Circle Entity Secret (REQUIRED for DCW transfers) ---
# Get from: https://console.circle.com → Developer Controlled Wallets → Entity Secret
# Must be a 32-byte hex string (64 chars)
CIRCLE_ENTITY_SECRET=your_64_char_hex_entity_secret_here

# --- Circle USDC Token on Arc Testnet (REQUIRED) ---
# Get from Circle Console → Arc Testnet token list
ARC_USDC_TOKEN_ID=your_arc_usdc_token_id_here
ARC_USDC_CONTRACT=0x0000000000000000000000000000000000000001

# --- Circle Agent Wallets (REQUIRED) ---
# Create 5 wallets in Circle Console → Developer Controlled Wallets → Wallet Sets
# Fund each with testnet USDC via: https://faucet.circle.com

ORCHESTRATOR_WALLET_ID=your_orchestrator_wallet_id
ORCHESTRATOR_WALLET_ADDRESS=0xYourOrchestratorWalletAddress

DATA_ANALYST_WALLET_ID=your_data_analyst_wallet_id
DATA_ANALYST_WALLET_ADDRESS=0xYourDataAnalystWalletAddress

CONTENT_WRITER_WALLET_ID=your_content_writer_wallet_id
CONTENT_WRITER_WALLET_ADDRESS=0xYourContentWriterWalletAddress

CODE_REVIEWER_WALLET_ID=your_code_reviewer_wallet_id
CODE_REVIEWER_WALLET_ADDRESS=0xYourCodeReviewerWalletAddress

TRANSLATOR_WALLET_ID=your_translator_wallet_id
TRANSLATOR_WALLET_ADDRESS=0xYourTranslatorWalletAddress

# --- Gemini AI (REQUIRED for live AI responses) ---
# Get from: https://aistudio.google.com → API Keys
# If empty, demo runs with pre-written fallback responses
GEMINI_API_KEY=your_gemini_api_key_here

# --- Neon PostgreSQL (REQUIRED) ---
# Get free DB at: https://neon.tech → New Project → Connection String
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/agentflow?sslmode=require

# --- Arc EVM (pre-configured, no change needed) ---
ARC_RPC_URL=https://rpc.arc.circle.com/testnet
ARC_CHAIN_ID=60000

# --- App ---
PORT=8000
ENVIRONMENT=development

# --- Frontend ---
# Local dev: http://localhost:8000
# Production: set to your Railway backend URL
NEXT_PUBLIC_API_URL=http://localhost:8000
