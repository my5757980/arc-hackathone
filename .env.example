# =============================================================
# AgentFlow — Agentic Economy on Arc
# Copy this to .env and fill in your credentials
# =============================================================

# --- Circle ---
CIRCLE_API_KEY=your_circle_api_key_here
ARC_USDC_TOKEN_ID=your_arc_usdc_token_id
ARC_USDC_CONTRACT=0x0000000000000000000000000000000000000001
ORCHESTRATOR_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# --- Gemini AI ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Neon PostgreSQL ---
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/agentflow?sslmode=require

# --- Arc EVM ---
ARC_RPC_URL=https://rpc.arc.circle.com/testnet
ARC_CHAIN_ID=60000

# --- App ---
PORT=8000
ENVIRONMENT=development

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
